[Unit]
Description=CADBRASIL Docs
After=network.target

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/www/wwwroot/cadbrasil-docs
Environment=PORT=3016
Environment=HOST=0.0.0.0
Environment=NODE_ENV=production
ExecStart=/www/server/nodejs/v22.13.1/bin/node /www/wwwroot/cadbrasil-docs/.output/server/index.mjs
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
